<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://lime.openfl.org/project/1.0.4" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://lime.openfl.org/project/1.0.4 http://lime.openfl.org/xsd/project-1.0.4.xsd">
    <meta build-number="4" company="ChickenSwimmer2020" package="com.chickenswimmer2020.scifidungeoncrawler" description="description. does this show up in windows file explorer?" title="Sublevel Atlas-Zero"/>
    <app preloader="flixel.system.FlxPreloader" Path="export" file="Sublevel Atlas-Zero" main="Main"/>
    <window orientation="landscape" width="0" height="0" fps="60" antialiasing="0" background="0xFF000000"/> 


    <section if="windows">
        <set name="version_prefix" value="PROTOTYE: " /> <!--boom, fixed.-->
        <meta version="0.03.2"/> <!--i have to do the prototype PreFix seperately because windows compiler = stupid.-->
    </section>
    
    <section unless="windows">
        <meta version="PROTOTYPE: 0.03.2"/>
    </section>

    <!--apple can eat the corn out of my shit.-->
    <error value="Fuck nah. Outta here with that shit (PLATFORM_MAC_NOT_SUPPORTED)" if="mac" />
    <error value="Fuck nah. Outta here with that shit (PLATFORM_IOS_NOT_SUPPORTED)" if="ios" />

    <error value="In light of googles choices with how to control android APK installation, this platform is no longer supported.
should google choose to remove said policies, this platform will gain support again.
PLATFORM_ANDROID_NOT_SUPPORTED" if="android" />

    <!--linux upcoming? 👀-->
    <section if="hl||windows||linux"> <!--WHOOPS, FORGOT TO TELL WINDOWS TO USE THESE AS WELL!!--> 
        <window allow-high-dpi="true" hardware="true" vsync="true" width="1280" height="720"/> <!--default window params-->
    </section>

    <haxelib name="flixel"/>
    <haxelib name="flixel-ui"/>
    <haxelib name="flixel-addons"/>
    <haxelib name="openfl"/>
    <haxelib name="hxcpp"/>

    <source path="source" />
    <source path="source/debug" if="debug"/>
    <section if="html5">
        <assets path="assets" embed="true"/>
    </section>
    <section if="hl||windows">
        <assets path="assets"/>
    </section>
    <assets path="assets/debug" include="*.png" if="debug" /> <!-- for only debug assets. -->
    
    <assets path="assets/"    rename="assets"	exclude="*.ogg" if="web"/>
    <assets path="assets/"    rename="assets"	exclude="*.mp3" unless="web"/>

    <!--platform specific enabling and disabling for performance-->
    <haxedef name="FLX_NO_TOUCH" if="windows||html5||hl"/>

    <haxedef name="FLX_NO_DEBUG" unless="debug"/>
    <haxedef name="FLX_NO_HEALTH"/> <!--because im doing it myself.-->
    <haxedef name="FLX_NO_FOCUS_LOST_SCREEN"/>
    <haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

    <language name="en" /> <!--turns out en-US doesnt work. and it just has to be "en"-->
</project>