    </menubar>

    <splitter direction="vertical" width="100%" height="100%" verticalAlign="center" horizontalAlign="center">

        <splitter direction="horizontal" width="100%" height="70%"> <!--objects panel -->
            <vbox height="100%" width="100%"> <!-- objects panel -->
                <frame collapsible="true" text="Objects" width="100%" icon="assets/debug/cc_objectsPanel.png">    
                    <button id="addNewCutsceneObject" width="100%" text="Add new..." />
                </frame>

                <hbox width="100%" height="100%"> <!--TODO: figure out why and when this crashes.-->
                    <tree-view id="ActiveCutsceneObjects" width="100%" height="100%" styleName="full-width">
                        <!--TODO: make this properly only show when the list is empty-->
                        <!--<vbox horizontalAlign="center" verticalAlign="center" styleName="empty-contents-component">
                            <progress indeterminate="true" /> TODO: replace with spinner when possible
                            <label text="No Objects in scene!" horizontalAlign="center" verticalAlign="center" />
                        </vbox>-->

                        <!--default rendered item-->
                        <item-renderer layout="horizontal" width="50%">
                            <image id="icon" verticalAlign="center" />
                            <image id="properties" verticalAlign="center" />
                            <vbox width="100%">
                                <label id="name" verticalAlign="center" width="50%" />
                                <label id="path" verticalAlign="center" style="font-size:8;" width="100%" />
                            </vbox>
                        </item-renderer>

                        <!--groups-->
                        <item-renderer id="expandable" layout="horizontal" width="100%">
                            <image resource="haxeui-core/styles/shared/folder-light.png" verticalAlign="center" />
                            <label id="text" width="100%" verticalAlign="center" />
                            <image id="properties" verticalAlign="center" />
                            <hbox style="border-radius:3px;padding: 1px 3px;spacing:0;" width="100%" verticalAlign="center">
                                <button id="moveUp" width="40" text="U"/>
                                <button id="moveDown" width="40" text="D"/>
                            </hbox>
                        </item-renderer>
                    </tree-view>    
                </hbox>
            </vbox>

            <splitter id="PreviewSplitter" style="clip:true;" width="100%" height="100%"> <!-- preview -->
                <box id="PreviewRenderArea" width="100%" height="100%" style="background-color: #000000;">
                </box>
            </splitter>
        </splitter>



        <!--timeline stuff goes down here-->
        
        <scrollview id="TimeLine" width="100%" height="100%">
            <box width="100%" style="background-color: #FFFFAA;">
                <label text="Timeline" verticalAlign="center" horizontalAlign="center" />
            </box>
        </scrollview>
    </splitter>     
</vbox>