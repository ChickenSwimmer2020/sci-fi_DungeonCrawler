<vbox width="100%" height="100%"> <!--THIS. IS. A. TEST.-->
    <menubar id="menuBar" width="100%">
        <menu id="File" text="File">
            <menuitem id="NewCutscene" text="New Cutscene" shortcutText="Ctrl+F+N"/>
            <menuitem id="LoadCutscene" text="Load Cutscene" shortcutText="Ctrl+F+L"/>
            <menuseparator />
            <menuitem id="SaveCutscene" text="Save" shortcutText="Ctrl+S"/>
            <menuitem id="SaveCutsceneSEPERATE" text="Save as..." shortcutText="Ctrl+Shift+S"/>
            <menuseparator />
            <menuitem id="QuitEditor" text="Quit" shortcutText="Ctrl+Q" />
        </menu>

        <menu id="Meta" text="Meta">
            <hbox width="100%">
                <label id="MetaFPS" text="Frames Per Second" width="75%" verticalAlign="center" />
                <textfield id="FRAMESPERSECOND" width="25%" restrictChars="0-9" validator="required" text="60" />
            </hbox>

            <hbox width="100%">
                <label id="MetaTF" text="Total Frames" width="75%" verticalAlign="center" />
                <textfield id="TOTALFRAMESINPUT" width="25%" restrictChars="0-9" validator="required" text="120" />
            </hbox>
            <menuseparator />
            <menucheckbox text="Item 4" selected="true" />
            <menucheckbox text="Item 5" />
            <menucheckbox text="Item 6" selected="true" />
            <menuseparator />
            <menuoptionbox text="Item 7" />
            <menuoptionbox text="Item 8" />
            <menuoptionbox text="Item 9" selected="true" />
            <menuseparator />
            <menuoptionbox text="Item 10" group="somegroup" />
            <menuoptionbox text="Item 11" group="somegroup" selected="true" />
            <menuoptionbox text="Item 12" group="somegroup" />
        </menu>

        <menu id="Os" text="Onion Skinning">
            <menucheckbox id="OnionSkinToggle" text="Enabled" selected="true" />

            <hbox width="100%">
                <label id="OsPreFrames" text="Pre Frames" width="75%" verticalAlign="center" />
                <number-stepper id="OnionSkinPreframes" pos="2" />
            </hbox>

            <hbox width="100%">
                <label id="OsPostFrames" text="Post Frames" width="75%" verticalAlign="center" />
                <number-stepper id="OnionSkinPostframes" pos="2" />
            </hbox>
        </menu>

        <menu id="View" text="View">
            <menucheckbox id="ToggleUIDarkMode" text="Dark Mode" selected="true" />
        </menu>

        <button id="PlayCutscene" width="10%" text="Play" />
        <button id="TestCutscene" width="10%" text="Test" />

        


