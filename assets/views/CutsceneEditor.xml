    </menubar>

    <splitter direction="vertical" width="100%" height="100%" verticalAlign="center" horizontalAlign="center">
        <splitter direction="horizontal" width="100%" height="70%"> <!--objects panel -->
            <vbox height="100%" width="100%"> <!-- objects panel -->
                <frame id="objectsFrame" collapsible="true" text="Objects" width="100%" icon="assets/debug/cc_objectsPanel.png">    
                    <button id="addNewCutsceneObject" width="100%" text="Add new..." />
                </frame>

                <hbox width="100%" height="100%"> 
                    <tree-view id="ActiveCutsceneObjects" width="100%" height="100%" styleName="full-width">
                        <!--<vbox horizontalAlign="center" verticalAlign="center" styleName="empty-contents-component">
                            <progress indeterminate="true" /> 
                            <label text="No Objects in scene!" horizontalAlign="center" verticalAlign="center" />
                        </vbox>-->

                        <!--default rendered item-->
                        <item-renderer layout="horizontal" width="50%">
                            <image id="icon" verticalAlign="center" />
                            <image id="properties" verticalAlign="center" />
                            <vbox width="100%">
                                <label id="name" verticalAlign="center" width="50%" />
                                <label id="path" verticalAlign="center" style="font-size:8;" width="100%" />
                            </vbox>
                        </item-renderer>

                        <!--groups-->
                        <item-renderer id="expandable" layout="horizontal" width="100%">
                            <image resource="haxeui-core/styles/shared/folder-light.png" verticalAlign="center" />
                            <label id="text" width="100%" verticalAlign="center" />
                            <image id="properties" verticalAlign="center" />
                            <hbox style="border-radius:3px;padding: 1px 3px;spacing:0;" width="100%" verticalAlign="center">
                                <button id="moveUp" width="40" text="U"/>
                                <button id="moveDown" width="40" text="D"/>
                            </hbox>
                        </item-renderer>
                    </tree-view>    
                </hbox>
            </vbox>

            <splitter id="PreviewSplitter" style="clip:true;" width="100%" height="100%"> <!-- preview -->
                <box id="PreviewRenderArea" width="100%" height="100%" style="background-color: #000000;">
                </box>
            </splitter>
        </splitter>


        <!--timeline stuff goes down here-->
        <vbox id="TimeLine" width="100%" height="100%">
            <hbox width="100%" height="32" verticalAlign="center" style="padding:4px 8px;spacing:6px;">
                <label id="TL_Label" text="Timeline" verticalAlign="center" />
                <button id="TL_Play" width="32" text="▶" />
                <button id="TL_Stop" width="32" text="■" />
                <button id="TL_PrevFrame" width="32" text="◀" />
                <button id="TL_NextFrame" width="32" text="▶|" />
                <!--<separator direction="vertical" height="16" />-->
                <button id="TL_AddKeyframe" text="◆ keyframe" />
                <button id="TL_AddBlank" text="◇ blank" />
                <button id="TL_AddTween" text="⟿ tween" />
                <!--<separator direction="vertical" height="16" />-->
                <button id="TL_AddLayer" width="32" text="+" />
                <button id="TL_RemoveLayer" width="32" text="-" />
                <label id="TL_FrameCounter" text="F: 1" verticalAlign="center" />
            </hbox>

            <hbox width="100%" height="100%">
                <!-- layer names panel, fixed width, scrolls vertically in sync -->
                <vbox id="TL_LayersDisplay" width="150" height="100%" style="border-right: 1px solid #444444;">
                    <!-- header row to align with frame numbers -->
                    <hbox width="100%" height="24" style="border-bottom: 1px solid #444444;">
                        <label text="Layer" verticalAlign="center" style="font-size:10;padding-left:4px;" />
                    </hbox>
                    <!-- layer rows get added here dynamically -->
                    <scrollview id="TL_LayerNamesScroll" width="100%" height="100%">
                        <grid columns="1" id="TL_LayerNamesList" width="100%" height="100%"/>
                    </scrollview>
                </vbox>

                <!-- keyframe area, scrolls both axes -->
                <scrollview id="TL_KFArea" width="100%" height="100%">
                    <vbox id="TL_KFContent" width="100%">
                        <!-- frame number ruler -->
                        <hbox id="TL_FrameRuler" width="100%" height="24" style="border-bottom: 1px solid #444444;" />
                        <!-- keyframe rows get added here dynamically, one hbox per layer -->
                        <vbox id="TL_LayerRows" width="100%" />
                    </vbox>
                </scrollview>

            </hbox>
        </vbox>
    </splitter>     
</vbox>