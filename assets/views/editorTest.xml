    <menubar width="100%">
        <menu text="File">
            <menuitem text="New Cutscene" shortcutText="Ctrl+F+N"/>
            <menuitem text="Load Cutscene" shortcutText="Ctrl+F+L"/>
            <menuseparator />
            <menuitem text="Quit" shortcutText="Ctrl+Q" />
        </menu>

        <menu text="Save">
            <menuitem text="Save" shortcutText="Ctrl+S"/>
            <menuitem text="Save as..." shortcutText="Ctrl+Shift+S"/>
        </menu>

        <menu text="Play">
            <menuitem text="Play" shortcutText="Ctrl+P"/>
            <menuitem text="Test" shortcutText="Ctrl+Shift+P"/>
        </menu>

        <menu text="OnionSkinning">
            <menucheckbox text="Enabled" selected="true" />
            <section-header text="Back" />
            <number-stepper pos="2" />
            <section-header text="Forward" />
            <number-stepper pos="2" />
        </menu>


